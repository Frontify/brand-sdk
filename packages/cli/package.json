{
    "name": "@frontify/frontify-cli",
    "type": "module",
    "version": "6.2.3",
    "author": "Frontify Developers <developers@frontify.com>",
    "repository": {
        "type": "git",
        "url": "https://github.com/Frontify/brand-sdk",
        "directory": "packages/cli"
    },
    "bin": {
        "frontify-cli": "dist/index.mjs"
    },
    "files": [
        "dist",
        "templates"
    ],
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "build": "vite build",
        "dev": "vite build --watch",
        "format": "prettier --write .",
        "lint": "eslint .",
        "lint:fix": "eslint --fix .",
        "start": "npm run build && node dist/index.mjs",
        "test": "vitest run --silent",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@fastify/cors": "^11.2.0",
        "@vitejs/plugin-react": "^6.0.2",
        "archiver": "^7.0.1",
        "cac": "^7.0.0",
        "conf": "^15.1.0",
        "esbuild": "^0.28.1",
        "fast-glob": "^3.3.3",
        "fastify": "^5.8.5",
        "glob-to-regexp": "^0.4.1",
        "open": "^11.0.0",
        "picocolors": "^1.1.1",
        "prompts": "^2.4.2",
        "vite": "^8.0.16",
        "vite-plugin-externals": "^0.6.2",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@frontify/eslint-config-basic": "^1.0.15",
        "@tony.ganchev/eslint-plugin-header": "^3.4.4",
        "@types/glob-to-regexp": "^0.4.4",
        "@types/mock-fs": "^4.13.4",
        "@types/node": "^22.19.15",
        "@types/prompts": "^2.4.9",
        "@types/ws": "8.18.1",
        "@vitest/coverage-v8": "4.1.9",
        "@vitest/ui": "^4.1.9",
        "eslint": "^10.5.0",
        "prettier": "^3.8.4",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    }
}

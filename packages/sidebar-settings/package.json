        "@types/react-dom": "^18.3.7",
        "oxfmt": "^0.52.0",
        "oxlint": "^1.75.0",
        "oxlint-tsgolint": "^7.0.2001",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "typescript": "^5.9.3",
        "vite": "^7.3.2",
